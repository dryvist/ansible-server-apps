---
# SOPS secrets template for dryvist/ansible-server-apps
#
# Copy, fill in real values, then encrypt:
#   cp secrets.enc.yaml.example secrets.enc.yaml
#   sops --encrypt --in-place secrets.enc.yaml
#
# To edit encrypted values:
#   sops secrets.enc.yaml
#
# Variables are consumed via `sops exec-env` which exports them as
# environment variables before running ansible-playbook. Once the
# `openbao_lxc` role lands and `openbao_available: true`, individual
# roles flip to OpenBao (`vault-agent`-rendered EnvironmentFiles) one
# PR at a time via the `<role>_secret_source` bridge variable.
#
# Doppler is NOT used for runtime secrets in this repo. The single
# exception is the `gh-workflow-tokens` Doppler project which provides
# `GH_PAT_RUNNER_TOKEN` for the `github_runner` role.

# Proxmox connection
PROXMOX_VE_HOSTNAME: pve.example.local
PROXMOX_VE_NODE: pve
PROXMOX_VE_GATEWAY: "192.168.0.1"
PROXMOX_DOMAIN: example.local
PROXMOX_SSH_KEY_PATH: /path/to/your/ssh/key
PROXMOX_DKR_SSH_KEY_PATH: /path/to/your/docker-vm/ssh/key

# Splunk HEC consumer (Splunk Enterprise itself lives in
# JacobPEvans/ansible-splunk; these are just the credentials Cribl
# needs to push events at it)
SPLUNK_HEC_TOKEN: your-token-here
SPLUNK_PASSWORD: your-token-here

# HAProxy
HAPROXY_STATS_PASSWORD: your-token-here

# Technitium DNS
TECHNITIUM_DNS_API_TOKEN: your-token-here

# Mailpit SMTP relay
MAILPIT_RELAY_HOST: smtp.example.com
MAILPIT_RELAY_PORT: "587"
MAILPIT_RELAY_USERNAME: your-email@example.com
MAILPIT_RELAY_PASSWORD: your-app-password-here

# SQL Server
MSSQL_SA_PASSWORD: your-strong-sa-password-here

# Qdrant Vector Database
QDRANT_API_KEY: your-qdrant-api-key-here

# OpenBao (placeholder; populated once openbao_lxc lands)
# OPENBAO_ADDR: https://openbao.example.local:8200
# OPENBAO_ROLE_ID: your-approle-role-id
# OPENBAO_SECRET_ID: your-approle-secret-id
