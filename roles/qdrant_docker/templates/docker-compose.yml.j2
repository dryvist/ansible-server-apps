---
services:
  qdrant:
    image: {{ qdrant_docker_image }}
    container_name: {{ qdrant_docker_container_name }}
    restart: unless-stopped
    ports:
      - "{{ qdrant_docker_http_port }}:6333"
      - "{{ qdrant_docker_grpc_port }}:6334"
    volumes:
      - {{ qdrant_docker_data_dir }}/storage:/qdrant/storage
      - {{ qdrant_docker_data_dir }}/snapshots:/qdrant/snapshots
      - {{ qdrant_docker_data_dir }}/config/config.yaml:/qdrant/config/production.yaml:ro
    environment:
      QDRANT__SERVICE__API_KEY: "{{ qdrant_docker_api_key }}"
