---
# Cribl Edge inputs configuration
# Generated by Ansible - do not edit manually

inputs:
{% for name, port in cribl_edge_syslog_port_mappings.items() %}
  in_syslog_{{ port }}:
    id: in_syslog_{{ port }}
    type: syslog
    disabled: false
    sendToRoutes: false
    connections:
      - output: splunk_hec
        pipeline: syslog
    host: "0.0.0.0"
    tcpPort: {{ port }}
    udpPort: {{ port }}
    pqEnabled: true
    fields:
      - name: type
        value: "'syslog'"

{% endfor %}
